# ─────────────────────────────────────────────────────────────
# Taste-Trip environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored and is read ONLY inside server-side
# API route handlers (app/api/*) via process.env. These values
# must NEVER be prefixed with NEXT_PUBLIC_ and never reach the browser.
# ─────────────────────────────────────────────────────────────

# Auth.js v5 session-cookie encryption secret. Generate with:
#   openssl rand -base64 32
# Required in both local dev AND production (Vercel).
AUTH_SECRET=

# AUTH_URL is only needed for local dev when the dev host is NOT localhost
# (Spotify's redirect-URI rules require 127.0.0.1, so we set it here).
# On Vercel, LEAVE THIS UNSET — Auth.js auto-detects from VERCEL_URL.
AUTH_URL=http://127.0.0.1:3000

# Google Gemini API key (from Google AI Studio). Used in lib/gemini.ts (server only).
GOOGLE_API_KEY=

# Spotify app credentials (from https://developer.spotify.com/dashboard).
# Client Credentials flow only — no user login in these phases.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Gemini model id.
# NOTE on free-tier quotas (observed 2026-07): each discovery makes 2 Gemini
# calls, and free-tier daily caps are per-model. gemini-2.5-flash was only
# ~20 req/day and gemini-2.0-flash is unavailable on free tier. We default to
# gemini-3.1-flash-lite: fast, high-quality, and with plenty of free-tier
# headroom (verified across all three personas). For maximum reliability,
# enable billing on the Google API key (removes daily caps + most 503s).
# Note: Gemma models (e.g. gemma-4-31b-it) have higher limits but were flaky
# through this flow and lower quality — not recommended here.
GEMINI_MODEL=gemini-3.1-flash-lite
