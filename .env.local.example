# ─────────────────────────────────────────────────────────────
# Taste-Trip environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored and is read ONLY inside server-side
# API route handlers (app/api/*) via process.env. These values
# must NEVER be prefixed with NEXT_PUBLIC_ and never reach the browser.
# ─────────────────────────────────────────────────────────────

# Google Gemini API key (from Google AI Studio). Used in lib/gemini.ts (server only).
GOOGLE_API_KEY=

# Spotify app credentials (from https://developer.spotify.com/dashboard).
# Client Credentials flow only — no user login in these phases.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Gemini model id.
# NOTE on free-tier quotas (observed 2026-07): gemini-2.5-flash allows only
# ~20 requests/day on the free tier, and gemini-2.0-flash is unavailable on
# free tier — so we default to gemini-2.5-flash-lite (higher free daily quota).
# Each discovery makes 2 Gemini calls. For a reliable demo, enable billing on
# the Google API key (removes daily caps + most 503s), then gemini-2.5-flash
# is the higher-quality choice. Override here as you like.
GEMINI_MODEL=gemini-2.5-flash-lite
